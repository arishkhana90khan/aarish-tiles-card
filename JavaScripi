// WhatsApp Order
function orderOnWhatsapp(tileName, tilePrice) {
    const phoneNumber = '919876543210'; // यहाँ real number डालें
    const message = `नमस्ते, मुझे ${tileName} टाइल ऑर्डर करनी है। कीमत: ₹${tilePrice}`;
    const whatsappUrl = `https://wa.me/${phoneNumber}?text=${encodeURIComponent(message)}`;
    window.open(whatsappUrl, '_blank');
}

